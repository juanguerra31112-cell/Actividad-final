{
  "name": "arenacore-backend",
  "version": "1.0.0",
  "description": "Backend API REST para ArenaCore - Plataforma de torneos de videojuegos",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "sh start.sh",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/migrate.js && node src/db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
